# Copy to .env.local and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# 纯数字手机号/邮箱登录时的显示名（可选）
VITE_DEFAULT_DISPLAY_NAME=猴猴

# Netlify Functions server-only variables (do not prefix with VITE_)
COZE_API_TOKEN=YOUR_COZE_PERSONAL_ACCESS_TOKEN
COZE_BOT_ID=7664841515671715881
COZE_API_BASE=https://api.coze.cn
